# Link-check exclusions.
# These hosts are teaching placeholders or lab-local services that only
# resolve on a learner's machine, never on a CI runner.

# Local lab services started by 00-local-lab-setup/docker-compose.yml
^https?://localhost(:\d+)?
^https?://127\.0\.0\.1(:\d+)?
^https?://0\.0\.0\.0(:\d+)?

# Docker Compose service names, resolvable only inside the lab network
^https?://jenkins(:\d+)?(/|$)
^https?://gitea(:\d+)?(/|$)
^https?://registry(:\d+)?(/|$)
^https?://agent(:\d+)?(/|$)

# Private / link-local ranges used in AWS and Kubernetes examples
^https?://10\.
^https?://172\.(1[6-9]|2[0-9]|3[01])\.
^https?://192\.168\.
^https?://169\.254\.

# Illustrative hostnames used in examples
^https?://.*\.example\.com
^https?://.*\.example\.org
^https?://.*\.internal
^https?://.*\.local

# ─── Jenkins ──────────────────────────────────────────────────────────────────
# Credentials for the Jenkins admin account.
# Change these before sharing this file with anyone.
JENKINS_ADMIN_ID=admin
JENKINS_ADMIN_PASSWORD=admin123

# ─── Gitea ────────────────────────────────────────────────────────────────────
# Credentials for the Gitea admin account.
# Jenkins uses these same credentials to clone repositories.
GITEA_ADMIN_USER=gitea-admin
GITEA_ADMIN_PASSWORD=gitea123
GITEA_ADMIN_EMAIL=admin@lab.local
